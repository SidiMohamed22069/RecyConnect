						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"role\": \"ADMIN\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/users/1/role",
							"host": ["{{baseUrl}}"],
							"path": ["api", "users", "1", "role"]
						}
					}
				},
				{
					"name": "Get User By Phone",
					"request": {
						"method": "GET",
						"header": [
							{"key": "Authorization", "value": "Bearer {{token}}"},
							{"key": "X-Device-Id", "value": "{{deviceId}}"}
						],
						"url": {
							"raw": "{{baseUrl}}/api/users/by-phone/78123456",
							"host": ["{{baseUrl}}"],
							"path": ["api", "users", "by-phone", "78123456"]
						}
					}
				},
				{
					"name": "Get User Stats",
					"request": {
						"method": "GET",
						"header": [
							{"key": "Authorization", "value": "Bearer {{token}}"},
							{"key": "X-Device-Id", "value": "{{deviceId}}"}
						],
						"url": {
							"raw": "{{baseUrl}}/api/users/1/stats",
							"host": ["{{baseUrl}}"],
							"path": ["api", "users", "1", "stats"]
						}
					}
				}
			]
		},
		{
			"name": "📦 Products",
			"item": [
				{
